{
  "name": "@agent-sh/harness-e2e",
  "version": "0.0.0",
  "description": "End-to-end harness running real LLM tool-call loops against @agent-sh/harness-* tools (Ollama + qwen3.5)",
  "license": "MIT",
  "author": "Avi Fenesh",
  "homepage": "https://github.com/avifenesh/tools/tree/main/packages/harness-e2e#readme",
  "bugs": {
    "url": "https://github.com/avifenesh/tools/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/avifenesh/tools.git",
    "directory": "packages/harness-e2e"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:hard:27b": "E2E_MODEL=qwen3.5:27b-q4_K_M vitest run test/read.e2e.hard.test.ts",
    "test:hard:8b": "E2E_MODEL=qwen3:8b vitest run test/read.e2e.hard.test.ts",
    "test:hard:bedrock": "E2E_BACKEND=bedrock vitest run test/read.e2e.hard.test.ts",
    "test:hard": "pnpm test:hard:27b; EXIT_27B=$?; ollama stop qwen3.5:27b-q4_K_M 2>/dev/null; sleep 10; pnpm test:hard:8b; EXIT_8B=$?; ollama stop qwen3:8b 2>/dev/null; [ \"$EXIT_27B\" -eq 0 ] && [ \"$EXIT_8B\" -eq 0 ]",
    "test:write:27b": "E2E_MODEL=qwen3.5:27b-q4_K_M vitest run test/write.e2e.hard.test.ts",
    "test:write:8b": "E2E_MODEL=qwen3:8b vitest run test/write.e2e.hard.test.ts",
    "test:write:bedrock": "E2E_BACKEND=bedrock vitest run test/write.e2e.hard.test.ts",
    "test:write:gemma:small": "E2E_MODEL=gemma4:e2b-it-q4_K_M vitest run test/write.e2e.hard.test.ts",
    "test:write:gemma:large": "E2E_MODEL=gemma4:26b-a4b-it-q4_K_M vitest run test/write.e2e.hard.test.ts",
